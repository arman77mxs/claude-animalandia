{
    "permissions": {
      "allow": [
        "Bash(npm run *)",
        "Bash(npx *)",
        "Bash(git *)",
        "Bash(vercel *)",
        "Bash(node *)",
        "Bash(curl localhost:*)",
        "WebFetch(*)",
        "mcp__playwright__*",
        "mcp__filesystem__*",
        "mcp__supabase__*",
        "mcp__github__*",
        "mcp__vercel__*"
      ],
      "deny": [
        "Bash(rm -rf /)",
        "Bash(sudo *)",
        "Bash(chmod 777 *)"
      ]
    },
    "env": {
      "NODE_ENV": "development",
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }