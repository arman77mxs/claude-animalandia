{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}",
        "SUPABASE_PROJECT_REF": "${SUPABASE_PROJECT_REF}",
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {
        "PLAYWRIGHT_HEADLESS": "false",
        "PLAYWRIGHT_SCREENSHOTS_DIR": ".claude/screenshots",
        "PLAYWRIGHT_BASE_URL": "http://localhost:3000"
      }
    },
    "filesystem": {
      "command": "/Users/akira/.local/share/fnm/node-versions/v22.22.0/installation/bin/mcp-server-filesystem",
      "args": ["/Users/akira/Documents/vscode2/template-2-claude-best-practices-pageUX 2"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "vercel-mcp@latest"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}",
        "VERCEL_TEAM_ID": "${VERCEL_TEAM_ID}"
      }
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "@next/devtools-mcp@latest"],
      "env": {}
    }
  }
}